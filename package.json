{
  "name": "ngKittyDebug",
  "version": "0.0.0",
  "scripts": {
    "ci": "pnpm install --frozen-lockfile",
    "ng": "ng",
    "start": "ng serve -o",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch",
    "deploy": "node --env-file=.env ./node_modules/@angular/cli/bin/ng deploy",
    "test:watch": "ng test --watch",
    "test:cov": "ng test --coverage --watch=false --coverage-reporters json-summary --coverage-reporters text",
    "lint": "eslint src && stylelint \"**/*.{css,scss}\" --ignore-path .gitignore",
    "lint:fix": "eslint src --fix && stylelint \"**/*.{css,scss}\" --fix --ignore-path .gitignore",
    "format": "prettier src --check",
    "format:fix": "prettier src -w",
    "typecheck": "tsc -b --noEmit",
    "prepare": "husky"
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "validate-branch-name": {
    "pattern": "^(chore|feat|fix|docs|style|refactor|perf|develop)\\/[a-zA-Z0-9-]+[_-][a-zA-Z0-9-]+$",
    "errorMsg": "Branch name is invalid."
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-angular": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@netlify-builder/deploy": "^5.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "less": "^4.6.4",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.1",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1",
    "validate-branch-name": "^1.3.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@netlify/identity": "^1.1.0",
    "@taiga-ui/addon-doc": "^5.5.0",
    "@taiga-ui/cdk": "^5.5.0",
    "@taiga-ui/core": "^5.5.0",
    "@taiga-ui/icons": "^5.5.0",
    "@taiga-ui/kit": "^5.5.0",
    "@taiga-ui/layout": "^5.5.0",
    "@taiga-ui/styles": "^5.5.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  }
}
