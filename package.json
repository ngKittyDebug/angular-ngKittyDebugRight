{
  "name": "ngKittyDebug",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:fast": "jest --maxWorkers=50% --passWithNoTests",
    "test:changed": "jest -o --maxWorkers=50%",
    "test:watch": "jest --watch --maxWorkers=50%",
    "test:cov": "jest --coverage --coverageReporters=text-summary --coverageReporters=text --coverageReporters=json-summary --coverageReporters=lcov",
    "lint": "eslint src --fix && stylelint \"**/*.{css,scss}\" --fix --ignore-path .gitignore",
    "format": "prettier src -w",
    "typecheck": "tsc -b --noEmit"
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "validate-branch-name": {
    "pattern": "^(chore|feat|fix|docs|style|refactor|perf)\\/[a-zA-Z0-9-]+_[a-zA-Z0-9-]+$",
    "errorMsg": "Branch name is invalid."
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-angular": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.1",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1",
    "validate-branch-name": "^1.3.2"
  },
  "dependencies": {
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  }
}
